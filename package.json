{
  "name": "@nuxtus/cli",
  "version": "2.1.0",
  "description": "Command line interface for Nuxtus projects.",
  "exports": "./build/src/cli.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuxtus/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "start": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/cli.ts",
    "start:windows": "nodemon --watch 'src/**/*.ts' --exec \"npx ts-node\" src/cli.ts",
    "create": "npm run build && npm run test",
    "build": "tsc -p .",
    "local": "sudo npm i -g && nuxtus",
    "refresh": "rm -rf ./node_modules ./package-lock.json && npm install"
  },
  "bin": {
    "nuxtus": "./build/src/cli.js"
  },
  "engines": {
    "node": "^16.11.0 || ^17.0.0 || ^18.0.0 || ^20.0.0 || ^24.0.0",
    "npm": ">=8.5.0"
  },
  "author": "Craig Harman",
  "license": "MIT",
  "devDependencies": {
    "@nuxtus/generator": "1.9.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "9.2.6",
    "@semantic-release/release-notes-generator": "12.1.0",
    "@types/clear": "0.1.4",
    "@types/figlet": "1.7.0",
    "@types/inquirer": "9.0.9",
    "@types/node": "24.12.0",
    "@types/nunjucks": "3.2.6",
    "nodemon": "3.1.14",
    "semantic-release": "23.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "dependencies": {
    "@directus/sdk": "^21.0.0",
    "chalk": "^5.0.0",
    "clear": "^0.1.0",
    "clui": "^0.3.6",
    "commander": "^12.0.0",
    "dotenv": "^17.0.0",
    "figlet": "^1.5.2",
    "inquirer": "^13.0.0",
    "nunjucks": "^3.2.3",
    "path": "^0.12.7"
  },
  "release": {
    "branches": "main",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "breaking": true,
              "release": "major"
            },
            {
              "type": "feat",
              "release": "minor"
            },
            {
              "type": "revert",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "minor"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "docs",
              "scope": "README",
              "release": "patch"
            },
            {
              "type": "chore",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogTitle": "Changelog"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "volta": {
    "node": "24.14.0"
  }
}
